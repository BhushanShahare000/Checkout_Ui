generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id    Int     @id @default(autoincrement())
  name  String
  price Float
  image String
  quantity Int
}

model Order {
  id          Int      @id @default(autoincrement())
  fullName    String
  email       String
  phoneNumber String
  pinCode     String
  city        String
  state       String
  totalAmount Float
  createdAt   DateTime @default(now())
}
